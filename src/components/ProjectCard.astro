---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}
const { project } = Astro.props;
---

<div class="card">
  <div class="card-inner">
    <div class="card-top">
      <span class="year">{project.year}</span>
      {project.caseStudy && <span class="badge">Case study</span>}
    </div>
    <h2 class="title">{project.title}</h2>
    <p class="description">{project.description}</p>
    <ul class="tags">
      {project.tags.map((tag) => <li>{tag}</li>)}
    </ul>
    <div class="card-footer">
      <a href={`${import.meta.env.BASE_URL}projects/${project.slug}`} class="btn">
        View case study <span class="arrow">→</span>
      </a>
    </div>
  </div>
</div>

<style>
  .card {
    position: relative;
    border: 1px solid var(--border-ui);
    border-radius: 4px;
    background: var(--card-bg);
  }



  .card-inner {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .year {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 400;
  }

  .badge {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
  }

  .title {
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--text);
  }

  .description {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin-top: 0.25rem;
  }

  .tags li {
    font-size: 0.8rem;
    color: var(--text-muted);
    background: #e4e8ef;
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
  }

  .card-footer {
    margin-top: 0.5rem;
  }

  .btn {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: #fff;
    background: linear-gradient(160deg, #6750a0, #4f3d8a);
    box-shadow: 0 1px 4px rgba(79, 61, 138, 0.2);
    padding: 0.5rem 1rem;
    border-radius: 3px;
    text-decoration: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .btn {
      transition: box-shadow 0.15s ease, background 0.15s ease;
    }
    .arrow {
      display: inline-block;
      transition: transform 0.15s ease;
    }
    .btn:hover .arrow {
      transform: translateX(4px);
    }
  }

  .btn:hover {
    background: linear-gradient(160deg, #6750a0, #3d2e6e);
    box-shadow: 0 2px 8px rgba(79, 61, 138, 0.28);
  }
</style>
