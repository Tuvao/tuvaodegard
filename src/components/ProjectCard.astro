---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}
const { project } = Astro.props;
---

<a href={`${import.meta.env.BASE_URL}projects/${project.slug}`} class="card">
  <div class="card-inner">
    <div class="card-top">
      <span class="year">{project.year}</span>
      {project.caseStudy && <span class="badge">Case study</span>}
    </div>
    <h2 class="title">{project.title}</h2>
    <p class="description">{project.description}</p>
    <ul class="tags">
      {project.tags.map((tag) => <li>{tag}</li>)}
    </ul>
  </div>
</a>

<style>
  .card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--card-bg);
    transition: border-color 0.15s ease;
  }

  .card:hover {
    border-color: var(--accent);
  }

  .card-inner {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .year {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 400;
  }

  .badge {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
  }

  .title {
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--text);
  }

  .description {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin-top: 0.25rem;
  }

  .tags li {
    font-size: 0.75rem;
    color: var(--text-muted);
    background: #ede9e2;
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
  }
</style>
