---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header>
      <a href={import.meta.env.BASE_URL} class="wordmark">Tuva Ødegård</a>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f5f2ed;
    --text: #1c1814;
    --text-muted: #7a726a;
    --accent: #a06830;
    --border: #e0dbd3;
    --card-bg: #faf8f5;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: "Inter", sans-serif;
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  header {
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 4rem;
  }

  .wordmark {
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--text);
    text-decoration: none;
  }

  .wordmark:hover {
    color: var(--accent);
  }

  a {
    color: inherit;
    text-decoration: none;
  }
</style>
