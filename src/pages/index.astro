---
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Tuva Ødegård — UX Designer & Frontend Developer">
  <section class="intro">
    <p class="intro-label">Frontend developer & UX designer</p>
    <h1>I bridge the gap between design and code.</h1>
    <p class="intro-bio">
      I care about the full picture: understanding what users actually need,
      shaping the interaction, then bringing it to life through programming.
      I have a sharp eye for detail and a drive to make things that genuinely
      work well.
    </p>
    <p class="intro-bio">
      Beyond the technical, I believe great work comes from curiosity, people
      skills and always wanting to get better.
    </p>
  </section>

  <h2 class="projects-heading">Some of my recent projects</h2>

  <ul class="project-list">
    {
      projects.map((project) => (
        <li>
          <ProjectCard project={project} />
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  .intro {
    margin-bottom: 3.5rem;
  }

  .intro-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: 1.9rem;
    font-weight: 400;
    line-height: 1.3;
    margin-bottom: 1.25rem;
  }

  .intro-bio {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .intro-bio + .intro-bio {
    margin-top: 0.75rem;
  }

  .projects-heading {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  .project-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
